# ─── HandOff.AI Backend — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development                    # development | staging | production
APP_SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO

# ── FastAPI server ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Fetch.ai uAgents ──────────────────────────────────────────────────────────
# Deterministic seed strings (keep secret — they derive the agent's wallet address)
CONTEXT_AGENT_SEED=context-agent-seed-jefferson
KNOWLEDGE_AGENT_SEED=knowledge-agent-seed-emily
VISION_AGENT_SEED=vision-agent-seed-gaida

# Agent ports (must not clash with FastAPI port)
CONTEXT_AGENT_PORT=8001
KNOWLEDGE_AGENT_PORT=8002
VISION_AGENT_PORT=8003

# Agentverse — get your API key at https://agentverse.ai → Settings → API Keys
# Set this to register agents on Agentverse so they appear in the marketplace
# and can be inspected at https://agentverse.ai/inspect/
AGENTVERSE_API_KEY=eyJhbGciOiJSUzI1NiJ9.eyJleHAiOjE3ODE5MDMyMjMsImlhdCI6MTc3NDEyNzIyMywiaXNzIjoiZmV0Y2guYWkiLCJqdGkiOiI4YWU1ZjMzNmM0Njc2MGUxZjk1MTBiZWYiLCJzY29wZSI6ImF2OmFpOnJvIGF2Omhvc3Rpbmc6cm8gYXY6bWFpbGJveCIsInN1YiI6IjFlZTFkMzIyNjZhZjg3MzY3M2ZhM2EwY2EyOGE4NzdiMTFiMGJhMTk3MmUzOTFmNyJ9.h-mRy1JIjp2niCi5H9UWb9-vhop6FiMMAQs68WGe3w6p5V0iDzXjGOIwZsa2phqCguAcm1-vzePEVcNubuVJbiiKe2bhX206kmFuilofSIjeH2v0vi5bemZTmGN3SUW0bnEBAqlYaPWkmrfMkSfpkxSbuoS-eLCSc5tq3Wi3Ski5KYU7-QhRT4kv2Vc-VbBeOSyeHu3NqKoNQzC73vA9BmOY2zEOv0o8FaJ5J3ppuClGJ6Kgk6osNoq457VtmsZ0qHuXptf3BcclgE9ETO2ZfDAf1kl_tSFg1lqnLJ_ItYgtZZmWWttLj2zDfEB32vrZjATHZOKhwAGHZyN7yFfauA

# ASI:One — optional LLM endpoint (OpenAI-compatible, uses model "asi1")
# Get your key at https://asi1.ai/dashboard/api-keys
# If set, the Context Agent will use ASI:One for reasoning instead of falling back to Gemini
# ASI1_API_KEY=your-asi1-api-key-here

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSyDCzLmXbF6M8G8S1WD_yrTV8lgD0fh7eCY
GEMINI_MODEL=gemini-1.5-pro             # gemini-1.5-pro for higher accuracy
GEMINI_VISION_TIMEOUT_SECONDS=10

# ── Firebase ──────────────────────────────────────────────────────────────────
# Path to your Firebase service account JSON (downloaded from Firebase console)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_REALTIME_DB_URL=https://handsoffai-63333-default-rtdb.firebaseio.com/

# ── Session & security ────────────────────────────────────────────────────────
SESSION_TTL_SECONDS=3600              # 1 hour
AUTOFILL_REQUIRE_CONFIRMATION=true
RECORD_MODE_REDACT_PASSWORDS=true
