# ── HandOff.AI Frontend Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your real values.

# ── Backend API (proxied via Vite — change for production) ────────────────────
VITE_API_BASE_URL=http://localhost:8000

# ── Firebase Web Config ────────────────────────────────────────────────────────
# Get from: Firebase console → Project Settings → Your apps → Web app → Config
# This is the CLIENT-SIDE config (NOT the service account JSON used by the backend).
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=handsoffai-63333.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://handsoffai-63333-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=handsoffai-63333
VITE_FIREBASE_STORAGE_BUCKET=handsoffai-63333.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
